{
  "name": "bavarium-browser",
  "productName": "Bavarium Browser",
  "version": "2.0.0-b",
  "bavariumDisplayVersion": "v2.0.0b",
  "description": "Bavarium Browser",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/patch-electron-win-metadata.cjs",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "yourworstnightmare1",
  "license": "ISC",
  "build": {
    "appId": "com.bavarium.browser",
    "productName": "Bavarium Browser",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!release/**",
      "!**/.DS_Store",
      {
        "from": "ultraviolet-app/node_modules",
        "to": "ultraviolet-app/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scramjet-app/node_modules",
        "to": "scramjet-app/node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "ultraviolet-app/**",
      "scramjet-app/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dir"
      ],
      "extendInfo": {
        "CFBundleName": "Bavarium Browser",
        "CFBundleDisplayName": "Bavarium Browser"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "npmRebuild": false
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "rcedit": "^4.0.1"
  },
  "dependencies": {
    "electron-native-share": "^0.1.1"
  }
}
